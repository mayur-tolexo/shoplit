{
	# Let's Encrypt registration address (set ACME_EMAIL in deploy/.env).
	email {$ACME_EMAIL}
}

# Redirect www → apex.
www.{$SITE_DOMAIN} {
	redir https://{$SITE_DOMAIN}{uri} permanent
}

# Single public origin. Caddy terminates TLS (auto Let's Encrypt) and routes by
# path prefix to the right service. Serving everything from one origin keeps
# the session cookie first-party — no CORS or cross-domain cookie issues.
{$SITE_DOMAIN} {
	encode zstd gzip

	# Creator API + Google OAuth + public read endpoints (all under /api).
	handle /api/* {
		reverse_proxy shoplit-api:8080
	}

	# Uploaded product/cover images, served by the API from a persistent volume.
	handle /uploads/* {
		reverse_proxy shoplit-api:8080
	}

	# Outbound click redirects / single-product short links.
	handle /go/* {
		reverse_proxy shoplit-redirect:8081
	}
	handle /p/* {
		reverse_proxy shoplit-redirect:8081
	}

	# Next.js build assets are content-hashed and immutable — keep them
	# cacheable (Next sets long cache headers; we don't override).
	handle /_next/* {
		reverse_proxy shoplit-web:3000
	}

	# App pages (documents + RSC flight payloads). Force no-store so the
	# browser can't cache a `text/x-component` RSC payload and then serve it
	# for a real navigation (which downloads the file instead of rendering —
	# the "download then reload fixes it" bug after the OAuth redirect).
	handle {
		reverse_proxy shoplit-web:3000 {
			header_down Cache-Control "no-store"
		}
	}
}
