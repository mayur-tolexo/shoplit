# Copy to deploy/.env on the server and fill in. NEVER commit deploy/.env.
#
#   cp deploy/.env.prod.example deploy/.env  &&  edit deploy/.env

# Your domain (apex, no scheme). www redirects to this automatically.
SITE_DOMAIN=shoplit.in
# Full public URL (scheme + apex). Used for OAuth redirect, CORS, frontend URL.
PUBLIC_URL=https://shoplit.in
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com

# Postgres password for the in-cluster database (pick something strong).
POSTGRES_PASSWORD=change-me-strong-password

# Session signing secret — generate with: openssl rand -hex 32
SHOPLIT_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Google OAuth 2.0 credentials (console.cloud.google.com).
# IMPORTANT: in the OAuth client, set
#   Authorized redirect URI:  https://shoplit.in/api/v1/auth/google/callback
#   Authorized JS origin:     https://shoplit.in
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
