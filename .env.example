# ─── shared ────────────────────────────────────────────────────────────
# DSN for shoplit-api (full read/write owner). Host port is 5433 (not 5432)
# so this stays out of the way of other postgres containers on the dev box.
SHOPLIT_DB_DSN=postgres://shoplit:shoplit@localhost:5433/shoplit?sslmode=disable
# DSN for shoplit-redirect. In dev this uses the same credentials as above
# for simplicity. In production this points to a SELECT-only role on the
# relevant tables, provisioned during deployment.
SHOPLIT_DB_DSN_READONLY=postgres://shoplit:shoplit@localhost:5433/shoplit?sslmode=disable

SHOPLIT_REDIS_URL=redis://localhost:6379/0

# Logging: debug | info | warn | error
SHOPLIT_LOG_LEVEL=info
# Environment label used in health output: dev | staging | prod
SHOPLIT_ENV=dev

# ─── shoplit-api ───────────────────────────────────────────────────────
SHOPLIT_API_ADDR=:8080

# ─── shoplit-redirect ──────────────────────────────────────────────────
SHOPLIT_REDIRECT_ADDR=:8081

# ─── shoplit-web (Next.js) ─────────────────────────────────────────────
# Disable Next.js usage telemetry so it doesn't spawn a detached-flush.js
# helper after `make down`. https://nextjs.org/telemetry
NEXT_TELEMETRY_DISABLED=1
